#include <stdio.h>
#include <math.h>

struct Point { double x, y; };

int main() {
    struct Point p1, p2;
    printf("Point 1 - Enter x: "); scanf("%lf", &p1.x);
    printf("Point 1 - Enter y: "); scanf("%lf", &p1.y);
    printf("Point 2 - Enter x: "); scanf("%lf", &p2.x);
    printf("Point 2 - Enter y: "); scanf("%lf", &p2.y);
    double d = sqrt(pow(p2.x-p1.x,2) + pow(p2.y-p1.y,2));
    printf("Distance: %.2f\n", d);
    return 0;
}

#include <stdio.h>

struct Student { char name[100]; int grade; };

int main() {
    struct Student s[3];
    int sum = 0;
    for (int i = 0; i < 3; i++) {
        printf("Student %d - name: ", i+1);  scanf("%s", s[i].name);
        printf("Student %d - grade: ", i+1); scanf("%d", &s[i].grade);
        sum += s[i].grade;
    }
    printf("\nAverage grade: %.2f\n", (double)sum / 3);
    return 0;
}
